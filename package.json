{
  "name": "draw-guess-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for Draw & Guess AI",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "setup": "npm install",
    "start": "concurrently --kill-others \"npm run backend\" \"npm run frontend\"",
    "backend": "node --env-file=.env backend/server.js",
    "frontend": "npx --env-file=.env webpack serve --config frontend/webpack.config.js",
    "build": "npm run build -w frontend",
    "stop": "pkill -f 'server.js' && pkill -f 'webpack'"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
