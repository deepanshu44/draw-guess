{
  "name": "draw-guess-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for Draw & Guess AI",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "concurrently --kill-others \"npm start -w backend\" \"npm start -w frontend\"",
    "build": "npm run build -w frontend",
    "stop": "pkill -f 'server.js' && pkill -f 'webpack'"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
