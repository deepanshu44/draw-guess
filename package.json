{
  "name": "draw-guess-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for Draw & Guess AI",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "concurrently --kill-others \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node --env-file=.env backend/server.js",
    "start:frontend": "node --env-file=.env node_modules/.bin/webpack serve --config frontend/webpack.config.js",
    "build": "npm run build -w frontend",
    "stop": "pkill -f 'server.js' && pkill -f 'webpack'"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
